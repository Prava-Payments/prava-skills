# Prava SDK Configuration — Next.js
# Copy this file to .env.local and fill in your credentials.
#
# Get your credentials from the Prava dashboard or your account manager.

# Prava backend URL
# Sandbox: https://sandbox.api.prava.space
# Production: https://api.prava.space
NEXT_PUBLIC_BACKEND_URL=https://sandbox.api.prava.space

# Your merchant secret key (SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_!)
# Sandbox keys start with: sk_test_
# Production keys start with: sk_live_
MERCHANT_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# Your publishable key (safe for client-side)
# Sandbox keys start with: pk_test_
# Production keys start with: pk_live_
NEXT_PUBLIC_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE
