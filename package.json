{
  "name": "@prava-sdk/cli",
  "version": "1.1.0",
  "description": "Prava CLI — smart wallet for AI agents",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Prava-Payments/prava-skills.git"
  },
  "homepage": "https://prava.space",
  "author": "Prava Payments",
  "bin": {
    "prava": "./dist/index.js"
  },
  "files": [
    "dist",
    "prava-pay",
    "prava-sdk-integration",
    "!**/docs",
    "!**/superpowers",
    "!**/results"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "eval:pay": "tsx prava-pay/evals/run.ts",
    "eval:pay:about": "tsx prava-pay/evals/about-run.ts",
    "eval:sdk": "tsx prava-sdk-integration/evals/run.ts",
    "eval:routing": "tsx evals/routing.ts"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
