{
  "name": "@prava-sdk/cli",
  "version": "0.0.1",
  "description": "CLI for AI agents to collect card payments via Prava",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Prava-Payments/prava-skills.git"
  },
  "homepage": "https://prava.space",
  "author": "Prava Payments",
  "bin": {
    "prava": "./dist/index.js"
  },
  "files": [
    "dist",
    "prava-agent-payments",
    "prava-sdk-integration",
    "!**/docs",
    "!**/superpowers"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
